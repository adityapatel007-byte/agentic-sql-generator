# Required for baseline
OPENAI_API_KEY=sk-...

# Optional for multi-model benchmark (v3)
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

# App config
LOG_LEVEL=INFO
MAX_AGENT_ITERATIONS=5
QUERY_TIMEOUT_SECONDS=15
MAX_RESULT_ROWS=200
DEFAULT_MODEL=gpt-5-nano
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Optional: separate embedding cache dir
CHROMA_PERSIST_DIR=./data/chroma

# CORS
ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://*
