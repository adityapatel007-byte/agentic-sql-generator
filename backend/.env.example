# Required for v1 baseline (Nemotron 3 Nano via NVIDIA NIM)
NVIDIA_API_KEY=nvapi-...

# Optional — used later for v3 multi-model benchmark
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# App config
LOG_LEVEL=INFO
MAX_AGENT_ITERATIONS=5
QUERY_TIMEOUT_SECONDS=15
MAX_RESULT_ROWS=200

# Model overrides — change the id here if a newer Nano ships or you're benchmarking
DEFAULT_MODEL=nvidia/nemotron-3-nano-30b-a3b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Storage
CHROMA_PERSIST_DIR=./data/chroma

# CORS
ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://*
